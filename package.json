{
  "name": "qa-automation-cypress",
  "version": "1.0.0",
  "description": "QA Automation learning project with Cypress (E2E).",
  "main": "index.js",
  "type": "commonjs",
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:open:qauto": "cypress open --config-file config/qauto.config.js",
    "cy:open:qauto2": "cypress open --config-file config/qauto2.config.js",
    "cy:run:qauto": "cypress run --config-file config/qauto.config.js",
    "cy:run:qauto2": "cypress run --config-file config/qauto2.config.js",
    "test:all": "npm run cy:run:qauto && npm run cy:run:qauto2",
    "test": "cypress run"
  },
  "keywords": [
    "cypress",
    "e2e",
    "qa",
    "automation"
  ],
  "author": "VladM",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^15.17.0",
    "mochawesome": "^7.1.4"
  }
}
